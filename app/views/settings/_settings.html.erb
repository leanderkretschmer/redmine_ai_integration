<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'ai_rewrite', plugin: 'redmine_ai_integration' %>
  <style>
    .provider-settings-section {
      border: 1px solid #ddd;
      border-radius: 6px;
      padding: 15px;
      margin: 15px 0;
      background: #f9f9f9;
    }
    
    .model-selection-group {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-top: 5px;
    }
    
    .load-models-btn {
      background: #5ca9dd;
      color: white;
      border: 1px solid #4a8bc7;
      padding: 6px 14px;
      border-radius: 3px;
      cursor: pointer;
      font-size: 13px;
      transition: background-color 0.2s;
    }
    
    .load-models-btn:hover {
      background: #4a8bc7;
    }
    
    .load-models-btn:disabled {
      background: #ccc;
      border-color: #bbb;
      cursor: not-allowed;
    }
    
    .advanced-settings {
      margin-top: 25px;
      border-top: 1px solid #ddd;
      padding-top: 20px;
    }
    
    .advanced-settings-toggle {
      background: #f2f2f2;
      border: 1px solid #ccc;
      color: #333;
      cursor: pointer;
      font-size: 13px;
      padding: 6px 12px;
      border-radius: 3px;
      text-decoration: none;
    }
    
    .advanced-settings-toggle:hover {
      background: #e8e8e8;
    }
    
    .advanced-settings-content {
      display: none;
      margin-top: 15px;
    }
    
    .advanced-settings-content.show {
      display: block;
    }
    
    .toggle-switch {
      position: relative;
      display: inline-block;
      width: 50px;
      height: 24px;
    }
    
    .toggle-switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }
    
    .toggle-slider {
      position: absolute;
      cursor: pointer;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: #ccc;
      transition: .4s;
      border-radius: 24px;
    }
    
    .toggle-slider:before {
      position: absolute;
      content: "";
      height: 16px;
      width: 16px;
      left: 4px;
      bottom: 4px;
      background-color: white;
      transition: .4s;
      border-radius: 50%;
    }
    
    input:checked + .toggle-slider {
      background-color: #4a90e2;
    }
    
    input:checked + .toggle-slider:before {
      transform: translateX(26px);
    }
    
    .toggle-label {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 10px 0;
    }
    
    .ai-checkbox-row {
       margin: 15px 0 5px 0;
       padding-left: 230px; /* 180px (standard label width) + 50px */
       display: flex;
       align-items: center;
       gap: 12px;
       font-size: 13px;
     }
    
    .ai-checkbox-row input[type="checkbox"] {
      margin: 0;
      width: 16px;
      height: 16px;
    }
    
    .ai-checkbox-row label, .ai-checkbox-row span {
      float: none !important;
      width: auto !important;
      margin: 0 !important;
      font-weight: normal;
      cursor: pointer;
    }

    .ai-checkbox-info {
      padding-left: 230px;
      margin-top: 0;
      margin-bottom: 15px;
    }
  </style>
<% end %>

<%= form_tag({ controller: 'settings', action: 'plugin', id: 'redmine_ai_integration' }, method: :post) do %>
  <div class="ai-integration-settings">
    <h3>AI Provider</h3>
    <p>
      <%= label_tag 'settings[ai_provider]', 'KI-Provider' %>
      <%= select_tag 'settings[ai_provider]', 
          options_for_select([
            ['OpenAI (ChatGPT)', 'openai'],
            ['Google Gemini', 'gemini'],
            ['Anthropic Claude', 'claude'],
            ['Ollama (Lokal)', 'ollama']
          ], @settings['ai_provider'] || 'openai'),
          id: 'ai_provider_select' %>
      <em class="info">Wählen Sie den KI-Provider für Textverbesserung und Chat</em>
    </p>

    <div id="openai_settings" class="provider_settings provider-settings-section" style="<%= 'display:none;' unless @settings['ai_provider'] == 'openai' %>">
      <h4>OpenAI (ChatGPT)</h4>
      <p>
        <%= label_tag 'settings[openai_api_key]', 'OpenAI API Key' %>
        <%= password_field_tag 'settings[openai_api_key]', @settings['openai_api_key'], size: 60 %>
        <em class="info">Ihr OpenAI API-Schlüssel</em>
      </p>
      <p>
        <%= label_tag 'settings[openai_model]', 'OpenAI Modell' %>
        <div class="model-selection-group">
          <%= text_field_tag 'settings[openai_model]', @settings['openai_model'] || 'gpt-3.5-turbo', size: 40, id: 'openai_model_input' %>
          <button type="button" id="openai_load_models" class="load-models-btn">Modelle laden</button>
          <select id="openai_model_select" style="display:none;"></select>
        </div>
        <em class="info">Verfügbare Modelle nach Klick auf "Modelle laden"</em>
      </p>
    </div>

    <div id="ollama_settings" class="provider_settings provider-settings-section" style="<%= 'display:none;' unless @settings['ai_provider'] == 'ollama' %>">
      <h4>Ollama (Lokal)</h4>
      <p>
        <%= label_tag 'settings[ollama_url]', 'Ollama URL' %>
        <%= text_field_tag 'settings[ollama_url]', @settings['ollama_url'] || 'http://localhost:11434', size: 60 %>
        <em class="info">URL zu Ihrer Ollama-Instanz (z.B. http://localhost:11434)</em>
      </p>
      <p>
        <%= label_tag 'settings[ollama_model]', 'Ollama Modell' %>
        <div class="model-selection-group">
          <%= text_field_tag 'settings[ollama_model]', @settings['ollama_model'] || 'llama2', size: 40, id: 'ollama_model_input' %>
          <button type="button" id="ollama_load_models" class="load-models-btn">Modelle laden</button>
          <select id="ollama_model_select" style="display:none;"></select>
        </div>
        <em class="info">Verfügbare Modelle nach Klick auf "Modelle laden"</em>
      </p>
      
      <div class="ai-checkbox-row">
        <%= check_box_tag 'settings[ollama_streaming]', '1', @settings['ollama_streaming'] == '1', id: 'ollama_streaming_toggle' %>
        <span onclick="document.getElementById('ollama_streaming_toggle').click()" style="cursor:pointer;">Streaming Response aktivieren</span>
      </div>
    </div>

    <div id="gemini_settings" class="provider_settings provider-settings-section" style="<%= 'display:none;' unless @settings['ai_provider'] == 'gemini' %>">
      <h4>Google Gemini</h4>
      <p>
        <%= label_tag 'settings[gemini_api_key]', 'Gemini API Key' %>
        <%= password_field_tag 'settings[gemini_api_key]', @settings['gemini_api_key'], size: 60 %>
        <em class="info">Ihr Google Gemini API-Schlüssel</em>
      </p>
      <p>
        <%= label_tag 'settings[gemini_model]', 'Gemini Modell' %>
        <div class="model-selection-group">
          <%= text_field_tag 'settings[gemini_model]', @settings['gemini_model'] || 'gemini-pro', size: 40, id: 'gemini_model_input' %>
          <button type="button" id="gemini_load_models" class="load-models-btn">Modelle laden</button>
          <select id="gemini_model_select" style="display:none;"></select>
        </div>
        <em class="info">Verfügbare Modelle nach Klick auf "Modelle laden"</em>
      </p>
    </div>

    <div id="claude_settings" class="provider_settings provider-settings-section" style="<%= 'display:none;' unless @settings['ai_provider'] == 'claude' %>">
      <h4>Anthropic Claude</h4>
      <p>
        <%= label_tag 'settings[claude_api_key]', 'Claude API Key' %>
        <%= password_field_tag 'settings[claude_api_key]', @settings['claude_api_key'], size: 60 %>
        <em class="info">Ihr Anthropic Claude API-Schlüssel</em>
      </p>
      <p>
        <%= label_tag 'settings[claude_model]', 'Claude Modell' %>
        <div class="model-selection-group">
          <%= text_field_tag 'settings[claude_model]', @settings['claude_model'] || 'claude-3-sonnet-20240229', size: 40, id: 'claude_model_input' %>
          <button type="button" id="claude_load_models" class="load-models-btn">Modelle laden</button>
          <select id="claude_model_select" style="display:none;"></select>
        </div>
        <em class="info">Verfügbare Modelle nach Klick auf "Modelle laden"</em>
      </p>
    </div>

    <div class="advanced-settings">
      <button type="button" class="advanced-settings-toggle" onclick="toggleAdvancedSettings()">
        Erweiterte Einstellungen anzeigen
      </button>
      
      <div class="advanced-settings-content" id="advanced_settings_content">
        <h4>System-Prompts</h4>
        <p>
          <%= label_tag 'settings[embedded_system_prompt]', 'Eingebetteter System-Prompt' %>
          <%= text_area_tag 'settings[embedded_system_prompt]', @settings['embedded_system_prompt'], rows: 3, cols: 80, style: 'width: 100%;' %>
          <em class="info">Standard-Prompt für eingebettete KI-Funktionen</em>
        </p>
        <p>
          <%= label_tag 'settings[system_prompt]', 'Optionaler System-Prompt' %>
          <%= text_area_tag 'settings[system_prompt]', @settings['system_prompt'], rows: 6, cols: 80, style: 'width: 100%;' %>
          <em class="info">Benutzerdefinierter Prompt für Textverbesserung</em>
        </p>
        
        <div class="ai-checkbox-row">
          <%= check_box_tag 'settings[slim_response]', '1', @settings['slim_response'] == '1', id: 'slim_response_toggle' %>
          <span onclick="document.getElementById('slim_response_toggle').click()" style="cursor:pointer;">Slim Response (nur das Wesentliche)</span>
        </div>
        
        <p class="ai-checkbox-info">
          <em class="info">Bei aktiviertem "Slim Response" wird ein optimierter Prompt verwendet, der nur das vom Benutzer Gewünschte zurückgibt.</em>
        </p>
      </div>
    </div>

    <h3>Verbindung testen</h3>
    <p>
      <button type="button" id="test_connection_btn" class="button">Verbindung testen</button>
      <span id="test_connection_status" style="margin-left: 10px;"></span>
    </p>
    <div id="test_connection_result" style="margin-top: 10px; display: none;">
      <div id="test_connection_message"></div>
      <div id="test_connection_models" style="margin-top: 10px;"></div>
    </div>
  </div>

  <%= submit_tag l(:button_save) %>
<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const providerSelect = document.getElementById('ai_provider_select');
    const providerSettings = document.querySelectorAll('.provider_settings');
    
    // Provider-Umschaltung
    providerSelect.addEventListener('change', function() {
      providerSettings.forEach(function(div) {
        div.style.display = 'none';
      });
      
      const selectedProvider = this.value;
      const selectedDiv = document.getElementById(selectedProvider + '_settings');
      if (selectedDiv) {
        selectedDiv.style.display = 'block';
      }
    });

    // Modelle laden Buttons
    const loadModelButtons = {
      openai: document.getElementById('openai_load_models'),
      ollama: document.getElementById('ollama_load_models'),
      gemini: document.getElementById('gemini_load_models'),
      claude: document.getElementById('claude_load_models')
    };

    Object.entries(loadModelButtons).forEach(([provider, button]) => {
      if (button) {
        button.addEventListener('click', function() {
          loadModelsForProvider(provider);
        });
      }
    });

    // Test Connection Button
    const testBtn = document.getElementById('test_connection_btn');
    const statusSpan = document.getElementById('test_connection_status');
    const resultDiv = document.getElementById('test_connection_result');
    const messageDiv = document.getElementById('test_connection_message');
    const modelsDiv = document.getElementById('test_connection_models');

    testBtn.addEventListener('click', function() {
      const provider = providerSelect.value;
      testBtn.disabled = true;
      statusSpan.textContent = 'Teste Verbindung...';
      statusSpan.style.color = '#666';
      resultDiv.style.display = 'none';

      fetch('/ai_rewrite/test_connection', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
        },
        body: JSON.stringify({ provider: provider })
      })
      .then(response => response.json())
      .then(data => {
        testBtn.disabled = false;
        resultDiv.style.display = 'block';

        if (data.success) {
          statusSpan.textContent = 'Erfolgreich';
          statusSpan.style.color = 'green';
          messageDiv.innerHTML = '<strong style="color: green;">' + (data.message || 'Verbindung erfolgreich') + '</strong>';
          
          if (data.models && data.models.length > 0) {
            modelsDiv.innerHTML = '<strong>Verfügbare Modelle:</strong><ul style="margin-top: 5px; margin-left: 20px;">' +
              data.models.map(function(model) {
                return '<li>' + model + '</li>';
              }).join('') + '</ul>';
          } else {
            modelsDiv.innerHTML = '';
          }
        } else {
          statusSpan.textContent = 'Fehler';
          statusSpan.style.color = 'red';
          messageDiv.innerHTML = '<strong style="color: red;">' + (data.message || 'Verbindung fehlgeschlagen') + '</strong>';
          modelsDiv.innerHTML = '';
        }
      })
      .catch(error => {
        testBtn.disabled = false;
        statusSpan.textContent = 'Fehler';
        statusSpan.style.color = 'red';
        messageDiv.innerHTML = '<strong style="color: red;">Verbindungsfehler: ' + error.message + '</strong>';
        modelsDiv.innerHTML = '';
      });
    });

    // Slim Response Toggle
    const slimResponseToggle = document.getElementById('slim_response_toggle');
    if (slimResponseToggle) {
      slimResponseToggle.addEventListener('change', function() {
        const systemPromptField = document.getElementById('settings_system_prompt');
        if (this.checked) {
          // Speichere aktuellen Prompt
          if (!window.originalSystemPrompt) {
            window.originalSystemPrompt = systemPromptField.value;
          }
          // Setze Slim Response Prompt
          systemPromptField.value = 'Antworte ausschließlich mit dem bearbeiteten Text, ohne jegliche Erklärungen oder einleitende Sätze.';
        } else {
          // Stelle Original-Prompt wieder her
          if (window.originalSystemPrompt) {
            systemPromptField.value = window.originalSystemPrompt;
          }
        }
      });
    }
  });

  function loadModelsForProvider(provider) {
    const button = document.getElementById(provider + '_load_models');
    const input = document.getElementById(provider + '_model_input');
    const select = document.getElementById(provider + '_model_select');
    
    button.disabled = true;
    button.textContent = 'Laden...';

    fetch('/ai_rewrite/test_connection', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({ provider: provider })
    })
    .then(response => response.json())
    .then(data => {
      button.disabled = false;
      button.textContent = 'Modelle laden';

      if (data.success && data.models && data.models.length > 0) {
        select.innerHTML = '';
        data.models.forEach(function(model) {
          const option = document.createElement('option');
          option.value = model;
          option.textContent = model;
          select.appendChild(option);
        });
        
        select.style.display = 'inline-block';
        select.addEventListener('change', function() {
          input.value = this.value;
        });
        
        // Automatisch erstes Modell auswählen
        if (data.models.length > 0) {
          input.value = data.models[0];
        }
      } else {
        alert('Keine Modelle gefunden oder Verbindungsfehler');
      }
    })
    .catch(error => {
      button.disabled = false;
      button.textContent = 'Modelle laden';
      alert('Fehler beim Laden der Modelle: ' + error.message);
    });
  }

  function toggleAdvancedSettings() {
    const content = document.getElementById('advanced_settings_content');
    const button = document.querySelector('.advanced-settings-toggle');
    
    if (content.classList.contains('show')) {
      content.classList.remove('show');
      button.textContent = 'Erweiterte Einstellungen anzeigen';
    } else {
      content.classList.add('show');
      button.textContent = 'Erweiterte Einstellungen ausblenden';
    }
  }
</script>