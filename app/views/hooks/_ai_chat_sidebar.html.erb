<div id="ai-chat-sidebar" class="ai-chat-container">
  <div class="ai-chat-header">
    <h3>KI-Assistent</h3>
    <button id="ai-chat-clear" class="ai-chat-clear-btn" onclick="clearAIChat()" title="Chat-Verlauf löschen">
      <span>Verlauf löschen</span>
    </button>
  </div>
  <div class="ai-chat-messages" id="ai-chat-messages">
    <div class="ai-chat-welcome">
      <p>Stellen Sie Fragen zu diesem Ticket. Ich analysiere alle Kommentare und Informationen für Sie.</p>
    </div>
  </div>
  
  <div class="ai-chat-input-container">
    <textarea id="ai-chat-input" placeholder="Frage stellen..." rows="2"></textarea>
    <button id="ai-chat-send" class="button ai-chat-send-btn" onclick="sendAIChatMessage()">
      <span>Fragen</span>
    </button>
  </div>
  
  <div id="ai-chat-loading" class="ai-chat-loading" style="display: none;">
    <span class="ai-chat-spinner"></span>
    <span>Analysiere...</span>
  </div>
</div>

<script>
// Globale Chat-Funktionen für einfache Einbindung
var currentIssueId = null;
var isChatLoading = false;

function initAIChat() {
  console.log('AI Chat Initialisierung gestartet');
  
  // Extrahiere Issue-ID aus URL
  const match = window.location.pathname.match(/\/issues\/(\d+)/);
  if (!match) {
    console.log('Keine Issue-Seite gefunden');
    return;
  }
  
  currentIssueId = match[1];
  console.log('Issue ID gefunden:', currentIssueId);
  
  // Event-Listener für Enter-Taste im Textfeld
  const input = document.getElementById('ai-chat-input');
  if (input) {
    input.addEventListener('keypress', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendAIChatMessage();
      }
    });
  }
  
  // Lade Chat-Historie
  loadAIChatHistory();
}

function sendAIChatMessage() {
  if (!currentIssueId || isChatLoading) return;
  
  const input = document.getElementById('ai-chat-input');
  const question = input.value.trim();
  
  if (!question) return;
  
  // Füge Frage zur Anzeige hinzu
  addAIChatMessage('user', question);
  input.value = '';
  
  // Zeige Lade-Indikator
  showAIChatLoading(true);
  
  // Sende Anfrage
  const formData = new FormData();
  formData.append('issue_id', currentIssueId);
  formData.append('question', question);
  
  fetch('/ai_chat/ask', {
    method: 'POST',
    body: formData,
    headers: {
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    }
  })
  .then(response => response.json())
  .then(data => {
    showAIChatLoading(false);
    
    if (data.error) {
      addAIChatMessage('error', 'Fehler: ' + data.error);
    } else {
      addAIChatMessage('ai', data.answer, data.journal_references);
    }
  })
  .catch(error => {
    showAIChatLoading(false);
    addAIChatMessage('error', 'Fehler: ' + error.message);
  });
}

function clearAIChat() {
  if (!currentIssueId || !confirm('Möchten Sie den Chat-Verlauf wirklich löschen?')) return;
  
  fetch('/ai_chat/clear', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    },
    body: JSON.stringify({ issue_id: currentIssueId })
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      // Leere das Nachrichten-Fenster
      const messagesContainer = document.getElementById('ai-chat-messages');
      messagesContainer.innerHTML = `
        <div class="ai-chat-welcome">
          <p>Stellen Sie Fragen zu diesem Ticket. Ich analysiere alle Kommentare und Informationen für Sie.</p>
        </div>
      `;
    } else {
      alert('Fehler beim Löschen des Verlaufs: ' + data.error);
    }
  })
  .catch(error => {
    console.error('Fehler beim Löschen des Verlaufs:', error);
    alert('Fehler beim Löschen des Verlaufs: ' + error.message);
  });
}

function addAIChatMessage(sender, content, journalReferences) {
  const messagesContainer = document.getElementById('ai-chat-messages');
  const welcomeMsg = messagesContainer.querySelector('.ai-chat-welcome');
  
  // Entferne Willkommensnachricht beim ersten Mal
  if (welcomeMsg && sender === 'user') {
    welcomeMsg.remove();
  }
  
  // Vermeide doppelte Nachrichten - prüfe auf vorhandene Nachrichten mit gleichem Inhalt
  const existingMessages = messagesContainer.querySelectorAll('.ai-chat-message');
  for (let msg of existingMessages) {
    const contentDiv = msg.querySelector('.ai-chat-content');
    if (contentDiv && contentDiv.textContent === content) {
      return; // Nachricht existiert bereits, nicht hinzufügen
    }
  }
  
  const messageDiv = document.createElement('div');
  messageDiv.className = 'ai-chat-message ai-chat-' + sender;
  
  const contentDiv = document.createElement('div');
  contentDiv.className = 'ai-chat-content';
  contentDiv.innerHTML = content; // HTML erlaubt für Links
  
  messageDiv.appendChild(contentDiv);
  
  // Füge Zeitstempel hinzu
  const timeDiv = document.createElement('div');
  timeDiv.className = 'ai-chat-time';
  timeDiv.textContent = new Date().toLocaleTimeString();
  messageDiv.appendChild(timeDiv);
  
  messagesContainer.appendChild(messageDiv);
  
  // Scrolle nach unten
  messagesContainer.scrollTop = messagesContainer.scrollHeight;
  
  // Füge Event-Listener für Journal-Links hinzu
  setupAIJournalLinks(contentDiv);
}

function setupAIJournalLinks(container) {
  const links = container.querySelectorAll('.ai-journal-link');
  links.forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      const journalId = this.dataset.journalId;
      scrollToAIJournal(journalId);
    });
  });
}

function scrollToAIJournal(journalId) {
  const journalElement = document.querySelector('#change-' + journalId);
  if (journalElement) {
    journalElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
    // Hebe das Element kurz hervor
    journalElement.style.backgroundColor = '#fffacd';
    setTimeout(() => {
      journalElement.style.backgroundColor = '';
    }, 2000);
  }
}

function showAIChatLoading(show) {
  isChatLoading = show;
  const loadingDiv = document.getElementById('ai-chat-loading');
  const sendBtn = document.getElementById('ai-chat-send');
  const input = document.getElementById('ai-chat-input');
  
  if (loadingDiv) {
    loadingDiv.style.display = show ? 'flex' : 'none';
  }
  
  if (sendBtn) {
    sendBtn.disabled = show;
    sendBtn.classList.toggle('ai-chat-disabled', show);
  }
  
  if (input) {
    input.disabled = show;
  }
}

function loadAIChatHistory() {
  if (!currentIssueId) return;
  
  fetch('/ai_chat/history?issue_id=' + currentIssueId, {
    method: 'GET',
    headers: {
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
    }
  })
  .then(response => response.json())
  .then(data => {
    if (data.messages && data.messages.length > 0) {
      // Entferne Willkommensnachricht
      const welcomeMsg = document.querySelector('.ai-chat-welcome');
      if (welcomeMsg) {
        welcomeMsg.remove();
      }
      
      // Zeige Historie
      data.messages.forEach(msg => {
        addAIChatMessage('user', msg.question);
        addAIChatMessage('ai', msg.answer, msg.journal_references);
      });
    }
  })
  .catch(error => {
    console.error('Fehler beim Laden des Chat-Verlaufs:', error);
  });
}

// Initialisierung beim Laden der Seite
function tryInitAIChat() {
  // Stelle sicher, dass die Sidebar geladen ist
  const sidebar = document.getElementById('sidebar');
  if (!sidebar) {
    console.log('Sidebar noch nicht geladen');
    return false;
  }
  
  // Stelle sicher, dass unser Container existiert
  const chatContainer = document.getElementById('ai-chat-sidebar');
  if (!chatContainer) {
    console.log('Chat-Container noch nicht geladen');
    return false;
  }
  
  initAIChat();
  return true;
}

// Versuche mehrmals zu initialisieren
let initAttempts = 0;
const maxAttempts = 10;

function scheduleInit() {
  if (initAttempts < maxAttempts) {
    initAttempts++;
    if (tryInitAIChat()) {
      console.log('AI Chat erfolgreich initialisiert');
    } else {
      setTimeout(scheduleInit, 1000); // Warte 1 Sekunde
    }
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', scheduleInit);
} else {
  // DOM ist bereits geladen
  scheduleInit();
}

// Fallback: Versuche es erneut, wenn die Seite vollständig geladen ist
window.addEventListener('load', function() {
  setTimeout(tryInitAIChat, 2000); // Warte 2 Sekunden
});
</script>